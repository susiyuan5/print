{
  "manifest_version": 3,
  "name": "PrintLab 趋势雷达抓取",
  "version": "1.5.2",
  "minimum_chrome_version": "138",
  "description": "精准提取当前 Chrome 标签页的具体项目，并在本机将说明翻译为中文后提交到趋势雷达。",
  "action": { "default_title": "提交当前页到趋势雷达", "default_popup": "popup.html" },
  "background": { "service_worker": "background.js", "type": "module" },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://127.0.0.1:3456/*",
    "https://*.cults3d.com/*",
    "https://*.printables.com/*",
    "https://*.makerworld.com/*",
    "https://*.thingiverse.com/*",
    "https://*.myminifactory.com/*",
    "https://*.etsy.com/*",
    "https://*.amazon.com/*",
    "https://*.amazon.ca/*",
    "https://*.tiktok.com/*",
    "https://*.instagram.com/*"
  ],
  "content_security_policy": { "extension_pages": "script-src 'self'; object-src 'self'" }
}
